{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Urls": "https://localhost:49940;http://localhost:49941",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=InclusiveCommunicationHub;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!@#$",
    "Issuer": "ICH.API",
    "Audience": "ICH.Clients",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "AzureSpeech": {
    "SubscriptionKey": "YOUR_AZURE_SPEECH_KEY",
    "Region": "eastus",
    "Endpoint": "https://eastus.api.cognitive.microsoft.com/"
  },
  "AzureTranslator": {
    "SubscriptionKey": "YOUR_AZURE_TRANSLATOR_KEY",
    "Endpoint": "https://api.cognitive.microsofttranslator.com",
    "Region": "eastus"
  },
  "AzureOpenAI": {
    "Endpoint": "https://your-openai.openai.azure.com/",
    "ApiKey": "YOUR_AZURE_OPENAI_KEY",
    "DeploymentName": "gpt-4o",
    "EmbeddingDeploymentName": "text-embedding-ada-002"
  },
  "AzureStorage": {
    "ConnectionString": "YOUR_AZURE_STORAGE_CONNECTION_STRING",
    "AudioContainerName": "audio-recordings",
    "TranscriptContainerName": "transcriptions",
    "SignLibraryContainerName": "sign-library"
  },
  "ResponsibleAI": {
    "RequireConsent": true,
    "AllowRecording": true,
    "AllowDeletion": true,
    "ShowAINotification": true,
    "MaxRetentionDays": 90
  },
  "AllowedHosts": "*"
}
